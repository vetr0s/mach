# Style for mach's own C. Matches STYLE.md: 4-space indent, ~100 columns,
# opening brace on the same line, no trailing whitespace. The vendored engine
# header (src/mach.h) is generated and excluded via .clang-format-ignore.
---
Language:        Cpp
BasedOnStyle:    LLVM
IndentWidth:     4
TabWidth:        4
UseTab:          Never
ColumnLimit:     100
BreakBeforeBraces: Attach
PointerAlignment: Right
DerivePointerAlignment: false
AlignAfterOpenBracket: Align
AllowShortFunctionsOnASingleLine: None
AllowShortIfStatementsOnASingleLine: false
AllowShortLoopsOnASingleLine: false
AllowShortBlocksOnASingleLine: Empty
KeepEmptyLinesAtTheStartOfBlocks: false
SpaceAfterCStyleCast: false
IndentCaseLabels: false
SortIncludes: false
...
